// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  password  String
  role      String    @default("USER")
  avatarUrl String?
  trips       Trip[]
  fuelEntries FuelEntry[]
  vehicles    Vehicle[] @relation("UserVehicles")

  @@map("users")
}

model Vehicle {
  id                   Int           @id @default(autoincrement())
  marca                String
  modelo               String
  anio                 Int
  placa                String        @default("")
  kilometrajeActual    Float
  valorCompra          Float
  valorAlquiler        Float         @default(0)
  valorReventaEstimado Float
  vidaUtilKm           Float
  rendimientoKmGalon   Float         @default(1)
  trips                Trip[]
  fuelEntries          FuelEntry[]
  maintenances         Maintenance[]
  documents            VehicleDocument[]
  ownerId              Int?
  owner                User?         @relation("UserVehicles", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@map("vehicles")
}

model Trip {
  id               Int      @id @default(autoincrement())
  fecha            DateTime
  ingresoBruto     Float
  kmRecorridos     Float
  gastoCombustible Float
  userId           Int
  vehicleId        Int
  user             User     @relation(fields: [userId], references: [id])
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([fecha])
  @@map("trips")
}

model VehicleDocument {
  id               Int      @id @default(autoincrement())
  tipo             String
  fechaExpedicion  DateTime
  fechaVencimiento DateTime
  vehicleId        Int
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("vehicle_documents")
}

model FuelEntry {
  id          Int      @id @default(autoincrement())
  fecha       DateTime
  cantidad    Float
  kilometraje Float
  costoTotal  Float    @default(0)
  userId      Int
  vehicleId   Int?
  user        User     @relation(fields: [userId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@map("fuel_entries")
}

model Maintenance {
  id                 Int       @id @default(autoincrement())
  descripcion        String
  categoria          String    @default("OTROS")
  intervaloKm        Float
  costoEstimado      Float
  status             String    @default("PENDIENTE")
  costoReal          Float?
  fechaEjecucion     DateTime?
  kilometrajeRegistro Float?
  vehicleId          Int?
  vehicle            Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("maintenances")
}
