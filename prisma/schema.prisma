// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  nombre String
  email String @unique
  trips Trip[]

  @@map("users")
}

model Vehicle {
  id                   Int     @id @default(autoincrement())
  marca                String
  modelo               String
  anio                 Int
  kilometrajeActual    Float
  valorCompra          Float
  valorReventaEstimado Float
  vidaUtilKm           Float
  trips                Trip[]

  @@map("vehicles")
}

model Trip {
  id               Int      @id @default(autoincrement())
  fecha            DateTime
  ingresoBruto     Float
  kmRecorridos     Float
  gastoCombustible Float
  userId           Int
  vehicleId        Int
  user             User     @relation(fields: [userId], references: [id])
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("trips")
  @@index([userId])
  @@index([vehicleId])
  @@index([fecha])
}

model Maintenance {
  id             Int     @id @default(autoincrement())
  descripcion    String
  intervaloKm    Float
  costoEstimado  Float

  @@map("maintenances")
}
